def build_llm_context(dataset_id: str, user_rule: str) -> dict:
    dataset = get_dataset_metadata(dataset_id)
    parsed_sql = get_parsed_sql_boundary(dataset_id)
    scope_columns = get_scope_columns(dataset_id)

    relevant_columns = shortlist_relevant_columns(user_rule, scope_columns)

    return {
        "dataset_context": {
            "dataset_id": dataset["dataset_id"],
            "application": dataset["application"],
            "lob": dataset["lob"],
            "domain": dataset["domain"]
        },
        "base_sql_boundary": {
            "output_columns": [c["name"] for c in relevant_columns],
            "tables": parsed_sql["tables"],
            "joins": parsed_sql["joins"][:5],
            "filters": parsed_sql["filters"][:5]
        },
        "scope_attributes": relevant_columns,
        "allowed_rule_templates": get_allowed_templates(),
        "output_schema": get_output_schema(),
        "user_rule": user_rule
    }
